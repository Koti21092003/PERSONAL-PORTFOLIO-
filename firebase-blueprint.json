{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the project" },
        "description": { "type": "string", "description": "Short description" },
        "techStack": { "type": "array", "items": { "type": "string" }, "description": "Technologies used" },
        "githubLink": { "type": "string", "format": "uri", "description": "GitHub repository link" },
        "liveLink": { "type": "string", "format": "uri", "description": "Live demo link" },
        "image": { "type": "string", "format": "uri", "description": "Project thumbnail image URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "description", "techStack", "githubLink", "liveLink", "image"]
    },
    "Message": {
      "title": "Message",
      "description": "A contact form message",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender's name" },
        "email": { "type": "string", "format": "email", "description": "Sender's email" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["name", "email", "message"]
    },
    "ProfileSettings": {
      "title": "ProfileSettings",
      "description": "Global profile settings",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "role": { "type": "string", "description": "Professional role" },
        "heroBio": { "type": "string", "description": "Short bio for hero section" },
        "aboutBio": { "type": "string", "description": "Detailed bio for about section" },
        "education": { "type": "string", "description": "Education details" },
        "goal": { "type": "string", "description": "Career goal" },
        "passion": { "type": "string", "description": "Professional passion" },
        "github": { "type": "string", "format": "uri", "description": "GitHub profile URL" },
        "linkedin": { "type": "string", "format": "uri", "description": "LinkedIn profile URL" },
        "email": { "type": "string", "format": "email", "description": "Contact email" },
        "resumeUrl": { "type": "string", "format": "uri", "description": "Resume PDF URL" },
        "profileImageUrl": { "type": "string", "format": "uri", "description": "Profile image URL" },
        "skills": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "level": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        }
      }
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "User's creation timestamp" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/projects": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    },
    "/messages": {
      "schema": "Message",
      "description": "Collection of contact form messages"
    },
    "/settings/profile": {
      "schema": "ProfileSettings",
      "description": "Global profile configuration"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and role"
    }
  }
}
